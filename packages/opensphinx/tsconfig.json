{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "opensphinx/react": ["./src/react/index.ts"],
      "opensphinx/engine": ["./src/engine/index.ts"],
      "opensphinx/schemas": ["./src/schemas/index.ts"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force"
  },
  "include": ["src", "test", "tsup.config.ts", "vitest.config.ts"]
}
